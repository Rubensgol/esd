SELECT 
    c.id_carro, 
    c.modelo, 
    c.placa, 
    l.nome AS nome_loja_atual,
    CASE 
        WHEN c.id_loja_atual = 1 THEN 1 
        ELSE 2 
    END AS prioridade_distancia
FROM Carro c
INNER JOIN Loja l ON c.id_loja_atual = l.id_loja
WHERE c.status = 'livre' 
ORDER BY prioridade_distancia ASC, c.id_carro ASC
LIMIT 1;

